{
  "name": "@tsaito18/tuicss-react",
  "version": "0.1.4",
  "description": "React components for TuiCss — a retro MS-DOS / terminal (TUI) style UI library. React 19, zero runtime dependencies.",
  "keywords": [
    "react",
    "tui",
    "tuicss",
    "dos",
    "terminal",
    "retro",
    "ui",
    "components",
    "css",
    "react-components"
  ],
  "license": "MIT",
  "author": "Taiga Saito <me@taigasaito.org>",
  "homepage": "https://github.com/tsaito18/tuicss-react#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tsaito18/tuicss-react.git"
  },
  "bugs": {
    "url": "https://github.com/tsaito18/tuicss-react/issues"
  },
  "type": "module",
  "packageManager": "pnpm@10.24.0",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "sideEffects": [
    "**/*.css"
  ],
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "scripts": {
    "clean": "node -e \"require('node:fs').rmSync('dist', { recursive: true, force: true })\"",
    "build": "pnpm run clean && pnpm run build:js && pnpm run build:css",
    "build:js": "tsup",
    "build:css": "node scripts/build-css.mjs",
    "check": "pnpm run typecheck && pnpm run test && pnpm run build && pnpm run lint:pkg && pnpm run check:types",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "prepublishOnly": "pnpm run check",
    "lint:pkg": "publint",
    "check:types": "attw --pack"
  },
  "peerDependencies": {
    "react": ">=19",
    "react-dom": ">=19"
  },
  "devDependencies": {
    "@arethetypeswrong/cli": "^0.18.4",
    "@storybook/addon-a11y": "9.1.20",
    "@storybook/addon-docs": "9.1.20",
    "@storybook/react-vite": "9.1.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.9",
    "jsdom": "^29.1.1",
    "publint": "^0.3.21",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "sass": "^1.101.0",
    "storybook": "9.1.20",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.6",
    "vitest": "^4.1.9"
  }
}
